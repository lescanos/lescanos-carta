# Copia este archivo como .env.local para desarrollo local con Supabase.
# Los valores correctos aparecen al ejecutar: npx supabase status
#
#   npx supabase start
#   npx supabase status   ← copia API URL y anon key desde aquí

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<pegar anon key de `supabase status`>
